# ============================================
# Codely AI Platform - Environment Variables
# Copy to .env and configure for your deployment
# ============================================

# ----- CORE LLM CONFIGURATION (REQUIRED) -----
OLLAMA_BASE_URL=http://localhost:11434
CODELY_CHAT_MODEL=llama3.2:3b
CODELY_EMBEDDING_MODEL=llama3.2:3b

# ----- API SERVER CONFIGURATION -----
CODELY_API_HOST=0.0.0.0
CODELY_API_PORT=8889

# ----- AUTHENTICATION (REQUIRED FOR PRODUCTION) -----
# Generate secret key: python -c "import secrets; print(secrets.token_hex(32))"
CODELY_AUTH_SECRET_KEY=
CODELY_AUTH_TOKEN_EXPIRY=86400
CODELY_AUTH_SESSION_EXPIRY=604800
CODELY_BASE_URL=http://localhost:8889

# ----- EMAIL/SMTP (OPTIONAL - CONSOLE FALLBACK AVAILABLE) -----
CODELY_SMTP_HOST=smtp.gmail.com
CODELY_SMTP_PORT=587
CODELY_SMTP_USER=
CODELY_SMTP_PASSWORD=
CODELY_SMTP_USE_TLS=true
CODELY_FROM_EMAIL=

# ----- PRODUCTION TUNING (OPTIONAL) -----
# Background task workers
CODELY_MAX_WORKERS=4
# Ollama timeout settings (seconds)
CODELY_CHAT_TIMEOUT=300
CODELY_EMBED_TIMEOUT=60
# User resource limits
CODELY_MAX_TASKS_PER_USER=2
CODELY_RATE_LIMIT_CHAT=60
CODELY_RATE_LIMIT_INGEST=10
# Vector store batch size
CODELY_BATCH_EMBED_SIZE=10